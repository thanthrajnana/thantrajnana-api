APP_NAME=Thantrajnana Unified API
API_PREFIX=/api/v1
DATABASE_URL=postgresql+psycopg://postgres:Thanthrajnana@localhost:5432/thanthrajnana
SECRET_KEY=replace-with-a-long-random-secret-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=1440

FRONTEND_URL=http://localhost:3000
STUDENT_FRONTEND_URL=http://localhost:3001
TEACHER_FRONTEND_URL=http://localhost:3002
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:3001,http://127.0.0.1:3001,http://localhost:3002,http://127.0.0.1:3002
ENVIRONMENT=development

ARDUINO_CLI_PATH=arduino-cli
ARDUINO_CLI_TIMEOUT_SECONDS=180
ENABLE_DEVICE_UPLOAD=false
